{
  "name": "miar-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 3004",
    "build": "astro build",
    "preview": "npm run preview:pages",
    "preview:pages": "npm run build && wrangler pages dev dist --port 3004 --compatibility-date=2026-05-12",
    "preview:static": "astro preview --host 0.0.0.0 --port 3005",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.0",
    "astro": "^6.3.1"
  },
  "devDependencies": {
    "wrangler": "^4.90.1"
  },
  "overrides": {
    "vite": "^7"
  }
}
