---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="MIAR Blogs Temporarily Unavailable"
  description="MIAR blog access is temporarily disabled while the public launch surface is narrowed."
  current="blogs"
>
  <main class="subpage-shell">
    <section class="subpage-hero">
      <p class="eyebrow">Blogs</p>
      <h1>This section is temporarily unavailable.</h1>
      <p class="lead">
        Public blog access is disabled for now while the primary site and
        submission path are being stabilized.
      </p>
      <p>
        <a class="button button-primary" href="/">Return home</a>
      </p>
    </section>
  </main>
</BaseLayout>
