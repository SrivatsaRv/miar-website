---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="MIAR Blogs"
  description="MIAR field notes on imagery analysis, change, and operational interpretation."
  current="blogs"
>
  <main class="subpage-shell">
    <section class="subpage-hero">
      <p class="eyebrow">Blogs</p>
      <h1>Field notes on imagery, change, and operational interpretation.</h1>
      <p class="lead">
        Short-form writing on repeated observation, scene compare, assessment
        discipline, and the product worldview behind MIAR.
      </p>
    </section>

    <section class="document-listing">
      <div class="document-grid document-grid-two">
        <article class="document-card">
          <span>Field note 01</span>
          <h3>Why MIAR starts with cadence, not classification</h3>
          <p>
            Why repeated observation matters more than a single clean classification
            result, and why scene memory matters in real workflows.
          </p>
          <div class="mini-links">
            <a href="/blogs/posts/why-miar-starts-with-cadence/">Read post</a>
          </div>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
