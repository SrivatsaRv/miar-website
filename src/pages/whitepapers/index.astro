---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="MIAR Whitepapers Temporarily Unavailable"
  description="MIAR whitepapers are temporarily unavailable while the public site is being tightened."
  current="whitepapers"
>
  <main class="subpage-shell">
    <section class="subpage-hero">
      <p class="eyebrow">Whitepapers</p>
      <h1>This section is temporarily unavailable.</h1>
      <p class="lead">
        Public whitepaper access is disabled for now while the main landing
        experience is being stabilized.
      </p>
      <p>
        <a class="button button-primary" href="/">Return home</a>
      </p>
    </section>
  </main>
</BaseLayout>
