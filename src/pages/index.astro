---
import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionsGraphic from "../components/SolutionsGraphic.astro";
import WaitlistVisual from "../components/WaitlistVisual.astro";
---

<BaseLayout
  title="MIAR | Operational Imagery Intelligence"
  description="MIAR reads repeat military imagery, compares each pass to baseline, and flags the changes that need review."
  current="home"
>
  <main>
    <section class="hero section-anchor" id="home">
      <div class="hero-stage">
        <img
          class="hero-scene"
          src="/imagery/hotan-airfield-hero.png"
          alt="Annotated satellite image of Hotan Prefecture Airbase with aircraft detections and intelligence summary"
          width="1752"
          height="898"
          loading="eager"
          fetchpriority="high"
        />

        <div class="hero-shell">
          <div class="hero-overlay">
            <p class="eyebrow hero-eyebrow">MIAR / Military Imagery Analysis & Recognition</p>
            <h1>MIAR reads repeat military imagery and flags what changed.</h1>
            <p class="hero-lead">
              It keeps baseline, detections, and scene history in one workflow so analysts can
              see what is present, what changed since the last pass, and what needs review.
            </p>

            <div class="hero-actions">
              <a class="button button-primary" href="#waitlist">Request access</a>
              <a class="button button-secondary" href="#solutions">View solutions</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="page-shell">
      <section class="band band-split section-anchor" id="solutions">
        <div class="section-copy">
          <p class="eyebrow">What It Does</p>
          <h2>Track sites, assets, and activity across repeat coverage.</h2>
          <p>
            MIAR is built for repeat-look work. It reads each new pass against earlier coverage,
            keeps the site baseline in view, and flags the changes that deserve analyst attention.
          </p>

          <div class="capability-list">
            <article class="capability-item">
              <span>Detection</span>
              <p>Detect aircraft, vehicles, equipment, structures, and visible activity in the current scene.</p>
            </article>

            <article class="capability-item">
              <span>Temporal compare</span>
              <p>Compare the new pass to earlier passes so routine movement is separated from real change.</p>
            </article>

            <article class="capability-item">
              <span>Operational output</span>
              <p>Return detections, change calls, and supporting context in a form analysts can review and hand off.</p>
            </article>
          </div>
        </div>

        <SolutionsGraphic />
      </section>

      <section class="band section-anchor" id="insights">
        <div class="about-shell">
          <div class="section-head">
            <p class="eyebrow">How It Works</p>
            <h2>Every new image is read against site history, not in isolation.</h2>
            <p>
              MIAR keeps earlier passes, baseline counts, and current detections together.
              That makes it easier to tell whether you are looking at routine activity,
              buildup, dispersal, damage, or a genuine change in posture.
            </p>
          </div>

          <WaitlistVisual />
        </div>

        <div class="insight-grid">
          <article class="insight-item">
            <span>01</span>
            <h3>Start from the baseline.</h3>
            <p>Keep the earlier scene, previous counts, and known layout in front of the analyst.</p>
          </article>

          <article class="insight-item">
            <span>02</span>
            <h3>Read the new pass against it.</h3>
            <p>Check the latest image against that baseline to see what appeared, moved, or dropped out.</p>
          </article>

          <article class="insight-item">
            <span>03</span>
            <h3>Flag what needs review.</h3>
            <p>Keep the change call tied to the image and site history so it can move into review and reporting.</p>
          </article>
        </div>
      </section>

      <section class="band waitlist-band section-anchor" id="waitlist">
        <div class="waitlist-shell">
          <div class="waitlist-copy">
            <p class="eyebrow">Request access</p>
            <h2>For teams that review repeat imagery and monitor military sites over time.</h2>
            <p>
              We are speaking with analysts, program teams, and platform groups working
              installation monitoring, activity tracking, movement, and change review day to day.
            </p>
          </div>

          <div class="waitlist-card">
            <form class="waitlist-form" id="waitlist-form" method="post" action="/api/waitlist/">
              <div class="honeypot-field" aria-hidden="true">
                <label>
                  Website
                  <input type="text" name="website" tabindex="-1" autocomplete="off" />
                </label>
              </div>

              <label>
                Full name
                <input type="text" name="name" autocomplete="name" placeholder="Asha Menon" />
              </label>

              <label>
                Work email
                <input
                  type="email"
                  name="email"
                  autocomplete="email"
                  placeholder="asha@organization.com"
                  required
                />
              </label>

              <label>
                Organization
                <input
                  type="text"
                  name="organization"
                  autocomplete="organization"
                  placeholder="Program office, defense lab, ISR team, platform company"
                />
              </label>

              <label>
                Role or team
                <input
                  type="text"
                  name="role"
                  autocomplete="organization-title"
                  placeholder="Program lead, analyst, product owner, GEOINT team"
                />
              </label>

              <label>
                Primary workflow
                <div class="select-shell">
                  <input type="hidden" name="interest" value="" required data-custom-select-input />
                  <select class="mobile-select" data-custom-select-mobile>
                    <option value="">Select one</option>
                    <option value="installation-monitoring">Installation monitoring</option>
                    <option value="force-posture-change">Force posture change</option>
                    <option value="activity-indications">Activity indications and warning</option>
                    <option value="platform-integration">Platform or workflow integration</option>
                  </select>
                  <div class="custom-select" data-custom-select>
                    <button
                      class="custom-select-trigger is-placeholder"
                      type="button"
                      aria-expanded="false"
                      data-custom-select-trigger
                    >
                      <span data-custom-select-value>Select one</span>
                    </button>
                    <div class="custom-select-menu" hidden data-custom-select-menu>
                      <button type="button" data-value="installation-monitoring">Installation monitoring</button>
                      <button type="button" data-value="force-posture-change">Force posture change</button>
                      <button type="button" data-value="activity-indications">Activity indications and warning</button>
                      <button type="button" data-value="platform-integration">Platform or workflow integration</button>
                    </div>
                  </div>
                </div>
              </label>

              <label>
                Operating focus
                <div class="select-shell">
                  <input type="hidden" name="focus" value="" required data-custom-select-input />
                  <select class="mobile-select" data-custom-select-mobile>
                    <option value="">Select one</option>
                    <option value="airfields-aviation">Airfields and aviation</option>
                    <option value="installations-basing">Installations and basing</option>
                    <option value="maritime-activity">Maritime activity</option>
                    <option value="logistics-ground-movement">Logistics and ground movement</option>
                    <option value="multi-domain">Multi-domain coverage</option>
                  </select>
                  <div class="custom-select" data-custom-select>
                    <button
                      class="custom-select-trigger is-placeholder"
                      type="button"
                      aria-expanded="false"
                      data-custom-select-trigger
                    >
                      <span data-custom-select-value>Select one</span>
                    </button>
                    <div class="custom-select-menu" hidden data-custom-select-menu>
                      <button type="button" data-value="airfields-aviation">Airfields and aviation</button>
                      <button type="button" data-value="installations-basing">Installations and basing</button>
                      <button type="button" data-value="maritime-activity">Maritime activity</button>
                      <button type="button" data-value="logistics-ground-movement">Logistics and ground movement</button>
                      <button type="button" data-value="multi-domain">Multi-domain coverage</button>
                    </div>
                  </div>
                </div>
              </label>

              <label>
                Program timing
                <div class="select-shell">
                  <input type="hidden" name="timeline" value="" data-custom-select-input />
                  <select class="mobile-select" data-custom-select-mobile>
                    <option value="">Select one</option>
                    <option value="active-evaluation">Active evaluation now</option>
                    <option value="0-3-months">Operational need in 0-3 months</option>
                    <option value="3-6-months">Operational need in 3-6 months</option>
                    <option value="longer-horizon">Longer-horizon research</option>
                  </select>
                  <div class="custom-select" data-custom-select>
                    <button
                      class="custom-select-trigger is-placeholder"
                      type="button"
                      aria-expanded="false"
                      data-custom-select-trigger
                    >
                      <span data-custom-select-value>Select one</span>
                    </button>
                    <div class="custom-select-menu" hidden data-custom-select-menu>
                      <button type="button" data-value="active-evaluation">Active evaluation now</button>
                      <button type="button" data-value="0-3-months">Operational need in 0-3 months</button>
                      <button type="button" data-value="3-6-months">Operational need in 3-6 months</button>
                      <button type="button" data-value="longer-horizon">Longer-horizon research</button>
                    </div>
                  </div>
                </div>
              </label>

              <label>
                Mission note
                <textarea
                  name="mission"
                  rows="4"
                  placeholder="Describe the monitoring or imagery review problem you need to solve."
                ></textarea>
              </label>

              <button class="button button-primary submit-button" type="submit">
                Request access
              </button>

              <p class="form-status" id="form-status" aria-live="polite"></p>
            </form>
          </div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
