---
import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionsGraphic from "../components/SolutionsGraphic.astro";
import WaitlistVisual from "../components/WaitlistVisual.astro";
---

<BaseLayout
  title="MIAR | Operational Imagery Intelligence"
  description="MIAR turns repeat military imagery into detections, temporal change, and assessment-ready operational signal."
  current="home"
>
  <main>
    <section class="hero section-anchor" id="home">
      <div class="hero-stage">
        <img
          class="hero-scene"
          src="/imagery/hotan-airfield-hero.png"
          alt="Annotated satellite image of Hotan Prefecture Airbase with aircraft detections and intelligence summary"
          width="1752"
          height="898"
          loading="eager"
          fetchpriority="high"
        />

        <div class="hero-shell">
          <div class="hero-overlay">
            <p class="eyebrow hero-eyebrow">MIAR / Military Imagery Analysis & Recognition</p>
            <h1>Operational signal from repeat military imagery.</h1>
            <p class="hero-lead">
              MIAR establishes baseline, detects change, and surfaces evidence that can survive
              operational review.
            </p>

            <div class="hero-actions">
              <a class="button button-primary" href="#waitlist">Request access</a>
              <a class="button button-secondary" href="#solutions">View solutions</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="page-shell">
      <section class="band band-split section-anchor" id="solutions">
        <div class="section-copy">
          <p class="eyebrow">Solutions</p>
          <h2>Built for installations, basing, assets, and force posture over time.</h2>
          <p>
            MIAR is built for teams that need more than a single-frame detection. It reads what is
            present, what changed, and which shifts matter enough to move downstream.
          </p>

          <div class="capability-list">
            <article class="capability-item">
              <span>Detection</span>
              <p>Assets, equipment, and scene activity surfaced with precise localization and decision-usable confidence.</p>
            </article>

            <article class="capability-item">
              <span>Temporal compare</span>
              <p>Every scene is measured against historical baseline so routine motion does not get mistaken for operational change.</p>
            </article>

            <article class="capability-item">
              <span>Operational output</span>
              <p>Outputs are structured for analyst review, downstream correlation, and assessment workflows that need evidence, not hype.</p>
            </article>
          </div>
        </div>

        <SolutionsGraphic />
      </section>

      <section class="band section-anchor" id="insights">
        <div class="about-shell">
          <div class="section-head">
            <p class="eyebrow">Operational insights</p>
            <h2>Built to keep scene memory attached to the read.</h2>
            <p>
              MIAR is designed so imagery does not lose context between detection and
              assessment. Scene history, evidence state, and confidence remain attached
              to the signal as it moves into review.
            </p>
          </div>

          <WaitlistVisual />
        </div>

        <div class="insight-grid">
          <article class="insight-item">
            <span>01</span>
            <h3>Read change as pattern, not noise.</h3>
            <p>Repeated scenes make buildup, dispersal, occupancy, and activity shifts legible at operational tempo.</p>
          </article>

          <article class="insight-item">
            <span>02</span>
            <h3>Keep evidence attached to the claim.</h3>
            <p>Recognition only matters when the underlying evidence can survive review, challenge, and handoff.</p>
          </article>

          <article class="insight-item">
            <span>03</span>
            <h3>Move cleanly into larger systems.</h3>
            <p>MIAR is designed to feed platform, correlation, and assessment layers that sit beyond the first read.</p>
          </article>
        </div>
      </section>

      <section class="band waitlist-band section-anchor" id="waitlist">
        <div class="waitlist-shell">
          <div class="waitlist-copy">
            <p class="eyebrow">Request access</p>
            <h2>For programs building persistent watch over military infrastructure and activity.</h2>
            <p>
              We are working with ISR teams, defense programs, and platform partners
              responsible for installation monitoring, force posture, and imagery-driven assessment.
            </p>
          </div>

          <div class="waitlist-card">
            <form class="waitlist-form" id="waitlist-form" method="post" action="/api/waitlist/">
              <div class="honeypot-field" aria-hidden="true">
                <label>
                  Website
                  <input type="text" name="website" tabindex="-1" autocomplete="off" />
                </label>
              </div>

              <label>
                Full name
                <input type="text" name="name" autocomplete="name" placeholder="Asha Menon" />
              </label>

              <label>
                Work email
                <input
                  type="email"
                  name="email"
                  autocomplete="email"
                  placeholder="asha@organization.com"
                  required
                />
              </label>

              <label>
                Organization
                <input
                  type="text"
                  name="organization"
                  autocomplete="organization"
                  placeholder="Program office, defense lab, ISR team, platform company"
                />
              </label>

              <label>
                Role or team
                <input
                  type="text"
                  name="role"
                  autocomplete="organization-title"
                  placeholder="Program lead, analyst, product owner, GEOINT team"
                />
              </label>

              <label>
                Primary workflow
                <select name="interest" required>
                  <option value="">Select one</option>
                  <option value="installation-monitoring">Installation monitoring</option>
                  <option value="force-posture-change">Force posture change</option>
                  <option value="activity-indications">Activity indications and warning</option>
                  <option value="platform-integration">Platform or workflow integration</option>
                </select>
              </label>

              <label>
                Operating focus
                <select name="focus" required>
                  <option value="">Select one</option>
                  <option value="airfields-aviation">Airfields and aviation</option>
                  <option value="installations-basing">Installations and basing</option>
                  <option value="maritime-activity">Maritime activity</option>
                  <option value="logistics-ground-movement">Logistics and ground movement</option>
                  <option value="multi-domain">Multi-domain coverage</option>
                </select>
              </label>

              <label>
                Program timing
                <select name="timeline">
                  <option value="">Select one</option>
                  <option value="active-evaluation">Active evaluation now</option>
                  <option value="0-3-months">Operational need in 0-3 months</option>
                  <option value="3-6-months">Operational need in 3-6 months</option>
                  <option value="longer-horizon">Longer-horizon research</option>
                </select>
              </label>

              <label>
                Mission note
                <textarea
                  name="mission"
                  rows="4"
                  placeholder="Describe the collection, monitoring, or assessment problem you need to solve."
                ></textarea>
              </label>

              <button class="button button-primary submit-button" type="submit">
                Request access
              </button>

              <p class="form-status" id="form-status" aria-live="polite"></p>
            </form>
          </div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
