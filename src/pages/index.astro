---
import BaseLayout from "../layouts/BaseLayout.astro";
import SolutionsGraphic from "../components/SolutionsGraphic.astro";
import WaitlistVisual from "../components/WaitlistVisual.astro";
---

<BaseLayout
  title="MIAR | Operational Imagery Intelligence"
  description="MIAR helps analysts compare repeat imagery, detect visible equipment and activity, and keep the evidence behind every finding."
  current="home"
>
  <main>
    <section class="hero section-anchor" id="home">
      <div class="hero-stage">
        <img
          class="hero-scene"
          src="/imagery/hotan-airfield-hero.png"
          alt="Annotated satellite image of Hotan Prefecture Airbase with aircraft detections and intelligence summary"
          width="1752"
          height="898"
          loading="eager"
          fetchpriority="high"
        />

        <div class="hero-shell">
          <div class="hero-overlay">
            <p class="eyebrow hero-eyebrow">Military-grade imagery intelligence, delivered at operational tempo</p>
            <h1>Know what changed before the next image arrives.</h1>
            <p class="hero-lead">
              MIAR helps analysts compare repeat imagery, detect visible equipment and
              activity, and keep the evidence behind every finding.
            </p>

            <div class="hero-actions">
              <a class="button button-primary" href="#waitlist">Request access</a>
              <a class="button button-secondary" href="#solutions">View capability flow</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="page-shell">
      <section class="band band-split section-anchor" id="solutions">
        <div class="section-copy">
          <p class="eyebrow">What It Does</p>
          <h2>Built for military sites, operating areas, and assets under repeated monitoring.</h2>
          <p>
            MIAR is built for teams monitoring airfields, bases, ports, logistics routes,
            launch areas, forward positions, and other areas of military interest. It helps
            analysts understand what is present, what has changed, what needs review, and
            what should be tasked next.
          </p>

          <div class="capability-list">
            <article class="capability-item">
              <span>Detection</span>
              <p>Identify aircraft, vehicles, equipment, structures, and visible activity in the scene, with confidence scores and analyst review built into the workflow.</p>
            </article>

            <article class="capability-item">
              <span>Compare</span>
              <p>Compare the latest image against earlier imagery of the same site to separate routine movement from meaningful change.</p>
            </article>

            <article class="capability-item">
              <span>Fusion</span>
              <p>Correlate EO, SAR, IR, and other available sources so analysts are not limited to one image type or one collection condition.</p>
            </article>

            <article class="capability-item">
              <span>Evidence</span>
              <p>Preserve the source image, detection, comparison result, confidence score, analyst decision, and audit trail behind every finding.</p>
            </article>
          </div>
        </div>

        <SolutionsGraphic />
      </section>

      <section class="band section-anchor" id="insights">
        <div class="about-shell">
          <div class="section-head">
            <p class="eyebrow">Multi-Payload</p>
            <h2>Multi-payload change detection for real-world collection conditions.</h2>
            <p>
              Military imagery is rarely perfect. EO may be blocked by cloud cover. SAR may
              reveal metallic objects or structural change when optical imagery is unavailable.
              IR may indicate recent activity through heat signatures. Non-imaging sources can
              add context around movement, alerts, and operating patterns.
            </p>
          </div>

          <WaitlistVisual />
        </div>

        <div class="insight-grid">
          <article class="insight-item">
            <span>EO</span>
            <h3>EO imagery</h3>
            <p>High-resolution visual review for clear-weather, daytime detection and classification.</p>
          </article>

          <article class="insight-item">
            <span>SAR</span>
            <h3>SAR imagery</h3>
            <p>All-weather, day/night sensing for structural change, metallic signatures, and activity under poor optical conditions.</p>
          </article>

          <article class="insight-item">
            <span>IR</span>
            <h3>IR imagery</h3>
            <p>Heat-based indicators for active engines, recently moved equipment, and thermal activity.</p>
          </article>

          <article class="insight-item">
            <span>OSINT</span>
            <h3>Contextual signals</h3>
            <p>Support from non-imaging sources such as ADS-B, AIS, NOTAMs, and other contextual feeds through the wider ReachDefence stack.</p>
          </article>
        </div>
      </section>

      <section class="band waitlist-band section-anchor" id="waitlist">
        <div class="waitlist-shell">
          <div class="waitlist-copy">
            <p class="eyebrow">Request access</p>
            <h2>For teams that need to monitor military activity over time.</h2>
            <p>
              MIAR is being built for defence analysts, geospatial intelligence teams,
              research groups, program teams, and platform owners working on military
              imagery analysis and change detection. If your team monitors military sites,
              operating areas, assets, or activity over time, we would like to speak with you.
            </p>
          </div>

          <div class="waitlist-card">
            <form class="waitlist-form" id="waitlist-form" method="post" action="/api/waitlist/">
              <div class="honeypot-field" aria-hidden="true">
                <label>
                  Website
                  <input type="text" name="website" tabindex="-1" autocomplete="off" />
                </label>
              </div>

              <label>
                Full name
                <input type="text" name="name" autocomplete="name" placeholder="Asha Menon" />
              </label>

              <label>
                Work email
                <input
                  type="email"
                  name="email"
                  autocomplete="email"
                  placeholder="asha@organization.com"
                  required
                />
              </label>

              <label>
                Organization
                <input
                  type="text"
                  name="organization"
                  autocomplete="organization"
                  placeholder="Program office, defense lab, ISR team, platform company"
                />
              </label>

              <label>
                Role or team
                <input
                  type="text"
                  name="role"
                  autocomplete="organization-title"
                  placeholder="Program lead, analyst, product owner, GEOINT team"
                />
              </label>

              <label>
                What do you need to monitor?
                <div class="select-shell">
                  <input type="hidden" name="interest" value="" required data-custom-select-input />
                  <select class="mobile-select" data-custom-select-mobile>
                    <option value="">Select one</option>
                    <option value="airfields-aviation-activity">Airfields and aviation activity</option>
                    <option value="bases-installations">Bases and installations</option>
                    <option value="ports-maritime-activity">Ports and maritime activity</option>
                    <option value="logistics-routes-staging">Logistics routes and staging areas</option>
                    <option value="ground-equipment-movement">Ground equipment and movement</option>
                    <option value="multi-payload-change-detection">Multi-payload change detection</option>
                    <option value="platform-system-integration">Platform or system integration</option>
                  </select>
                  <div class="custom-select" data-custom-select>
                    <button
                      class="custom-select-trigger is-placeholder"
                      type="button"
                      aria-expanded="false"
                      data-custom-select-trigger
                    >
                      <span data-custom-select-value>Select one</span>
                    </button>
                    <div class="custom-select-menu" hidden data-custom-select-menu>
                      <button type="button" data-value="airfields-aviation-activity">Airfields and aviation activity</button>
                      <button type="button" data-value="bases-installations">Bases and installations</button>
                      <button type="button" data-value="ports-maritime-activity">Ports and maritime activity</button>
                      <button type="button" data-value="logistics-routes-staging">Logistics routes and staging areas</button>
                      <button type="button" data-value="ground-equipment-movement">Ground equipment and movement</button>
                      <button type="button" data-value="multi-payload-change-detection">Multi-payload change detection</button>
                      <button type="button" data-value="platform-system-integration">Platform or system integration</button>
                    </div>
                  </div>
                </div>
              </label>

              <label>
                Primary area of interest
                <div class="select-shell">
                  <input type="hidden" name="focus" value="" required data-custom-select-input />
                  <select class="mobile-select" data-custom-select-mobile>
                    <option value="">Select one</option>
                    <option value="eo-imagery-analysis">EO imagery analysis</option>
                    <option value="sar-imagery-analysis">SAR imagery analysis</option>
                    <option value="ir-thermal-indicators">IR or thermal indicators</option>
                    <option value="multi-payload-fusion">Multi-payload fusion</option>
                    <option value="change-detection">Change detection</option>
                    <option value="tasking-revisit-planning">Tasking and revisit planning</option>
                    <option value="evidence-provenance">Evidence and provenance</option>
                  </select>
                  <div class="custom-select" data-custom-select>
                    <button
                      class="custom-select-trigger is-placeholder"
                      type="button"
                      aria-expanded="false"
                      data-custom-select-trigger
                    >
                      <span data-custom-select-value>Select one</span>
                    </button>
                    <div class="custom-select-menu" hidden data-custom-select-menu>
                      <button type="button" data-value="eo-imagery-analysis">EO imagery analysis</button>
                      <button type="button" data-value="sar-imagery-analysis">SAR imagery analysis</button>
                      <button type="button" data-value="ir-thermal-indicators">IR or thermal indicators</button>
                      <button type="button" data-value="multi-payload-fusion">Multi-payload fusion</button>
                      <button type="button" data-value="change-detection">Change detection</button>
                      <button type="button" data-value="tasking-revisit-planning">Tasking and revisit planning</button>
                      <button type="button" data-value="evidence-provenance">Evidence and provenance</button>
                    </div>
                  </div>
                </div>
              </label>

              <label>
                When do you need this capability?
                <div class="select-shell">
                  <input type="hidden" name="timeline" value="" data-custom-select-input />
                  <select class="mobile-select" data-custom-select-mobile>
                    <option value="">Select one</option>
                    <option value="evaluating-now">Evaluating now</option>
                    <option value="0-3-months">0 to 3 months</option>
                    <option value="3-6-months">3 to 6 months</option>
                    <option value="researching-for-later">Researching for later</option>
                  </select>
                  <div class="custom-select" data-custom-select>
                    <button
                      class="custom-select-trigger is-placeholder"
                      type="button"
                      aria-expanded="false"
                      data-custom-select-trigger
                    >
                      <span data-custom-select-value>Select one</span>
                    </button>
                    <div class="custom-select-menu" hidden data-custom-select-menu>
                      <button type="button" data-value="evaluating-now">Evaluating now</button>
                      <button type="button" data-value="0-3-months">0 to 3 months</button>
                      <button type="button" data-value="3-6-months">3 to 6 months</button>
                      <button type="button" data-value="researching-for-later">Researching for later</button>
                    </div>
                  </div>
                </div>
              </label>

              <label>
                What should we know about your use case?
                <textarea
                  name="mission"
                  rows="4"
                  placeholder="Describe the monitoring problem, site set, or imagery review workflow you need to support."
                ></textarea>
              </label>

              <button class="button button-primary submit-button" type="submit">
                Request access
              </button>

              <p class="form-status" id="form-status" aria-live="polite"></p>
            </form>
          </div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
